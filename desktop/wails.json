{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "BeamSync",
  "outputfilename": "BeamSync",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Pranav Agarkar",
    "email": "pranavagarkar8@gmail.com"
  },
  "info": {
    "companyName": "Pranav Agarkar",
    "productName": "BeamSync",
    "productVersion": "2.0.0",
    "copyright": "Copyright © 2025 Pranav Agarkar",
    "comments": "Fast LAN file transfer between desktop and mobile"
  },
  "build": {
    "windows": {
      "icon": "build/appicon/icon.ico",
      "webviewInstallationPolicy": "installIfMissing",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "darwin": {
      "icon": "build/appicon/icon.icns"
    },
    "linux": {
      "icon": "build/appicon/icon.png"
    }
  }
}